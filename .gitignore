# Whitelist-only repository export.
# Everything is ignored by default; only public open-source project files below
# are allowed into Git.
*

# Keep Git ignore rules and line-ending rules.
!.gitignore
!.gitattributes

# Public project metadata.
!README.md
!README.zh-CN.md
!LICENSE
!NOTICE
!CONTRIBUTING.md
!SECURITY.md

# Gradle project files.
!settings.gradle.kts
!build.gradle.kts
!gradle.properties
!gradlew
!gradlew.bat
!local.properties.example

# Android app module.
!app/
app/*
!app/build.gradle.kts
!app/src/
!app/src/**
!app/schemas/
!app/schemas/**

# Gradle wrapper.
!gradle/
gradle/*
!gradle/wrapper/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# GitHub repository configuration.
!.github/
!.github/**

# Public documentation only.
!docs/
docs/*
!docs/architecture.md
!docs/build.md
!docs/github_publishing.md
!docs/privacy.md
!docs/release_notes.md
!docs/technical_overview.md
!docs/web_development_experience.md
!docs/AI_HANDOFF.md
!docs/en/
docs/en/*
!docs/en/*.md
!docs/website/
!docs/website/*.md
!docs/screenshots/*
!docs/screenshots/README.md

# Public website.
!website/
website/*
!website/index.html
!website/privacy.html
!website/terms.html
!website/css/
!website/css/*.css
!website/js/
!website/js/*.js
!website/assets/
website/assets/*
!website/assets/icons.svg
!website/assets/*.png
!website/assets/*.jpg
!website/assets/*.jpeg
!website/assets/*.webp
!website/assets/*.svg
!website/assets/apk/
website/assets/apk/*
!website/assets/apk/*.apk
!website/assets/images/
website/assets/images/*
!website/assets/images/*.png
!website/assets/images/*.jpg
!website/assets/images/*.jpeg
!website/assets/images/*.webp
!website/assets/images/*.svg
!website/assets/images/screenshots/
website/assets/images/screenshots/*
!website/assets/images/screenshots/*.png
!website/assets/images/screenshots/*.jpg
!website/assets/images/screenshots/*.jpeg
!website/assets/images/screenshots/*.webp
!website/details/
!website/details/*.html

# Public helper scripts.
!scripts/
scripts/*
!scripts/windows/
!scripts/windows/*.bat

# Root Windows helper scripts.
!build_debug.bat
!build_release.bat
!compile_debug_apk.bat
!一键编译Debug.bat
!一键编译Release.bat
